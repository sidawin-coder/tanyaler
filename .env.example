# =============================================
# TanyaLer - Environment Variables
# Salin fail ini kepada .env.local
# =============================================

# Supabase (dapatkan dari https://app.supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OpenAI (dapatkan dari https://platform.openai.com)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

# BillPlz (dapatkan dari https://www.billplz.com/enterprise/api_key)
BILLPLZ_API_KEY=your-billplz-api-key
BILLPLZ_COLLECTION_ID=your-collection-id
BILLPLZ_X_SIGNATURE=your-x-signature-key

# App URL (tukar kepada domain anda bila deploy)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Guna 'sandbox' untuk testing, 'production' untuk live
BILLPLZ_MODE=sandbox
